{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "module": "commonjs",
    "moduleResolution": "node",
    "outDir": "dist-electron",
    "rootDir": ".",
    "types": ["node", "electron"]
  },
  "include": ["core/**/*.ts", "electron/**/*.ts", "electron/**/*.d.ts"],
  "exclude": ["node_modules", "dist-electron", "core/**/*.test.ts"]
}
