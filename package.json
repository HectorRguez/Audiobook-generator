{
  "name": "audiobook-generator",
  "version": "0.3.2",
  "private": true,
  "scripts": {
    "build:scripts": "tsc -p tsconfig.scripts.build.json",
    "dev:renderer": "cd renderer && next dev -H 127.0.0.1 -p 3000",
    "dev:tauri": "tauri dev",
    "dev": "npm run dev:tauri",
    "build:renderer": "cd renderer && cross-env BUILD_STATIC=1 next build",
    "build:desktop": "npm run build:tauri",
    "build:tauri": "tauri build",
    "build:runtime": "node --import tsx scripts/prepare-runtime.ts",
    "smoke:runtime": "node --import tsx scripts/smoke-runtime.ts",
    "build:voice-demos": "node --import tsx scripts/generate-voice-demos.ts",
    "collect:tauri-artifacts": "node --import tsx scripts/collect-tauri-artifacts.ts",
    "build:updater-manifest": "node --import tsx scripts/build-updater-manifest.ts",
    "build:site": "node --import tsx scripts/build-site.ts",
    "lint": "cd renderer && next lint",
    "test": "node --import tsx --test \"core/**/*.test.ts\"",
    "typecheck": "tsc -p tsconfig.scripts.json && cd renderer && tsc --noEmit"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/modifiers": "^9.0.0",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@radix-ui/react-select": "^2.2.6",
    "@tauri-apps/api": "^2.11.1",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "@tauri-apps/plugin-opener": "^2.5.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "epub2": "^3.0.2",
    "fast-xml-parser": "^5.2.5",
    "html-to-text": "^9.0.5",
    "lucide-react": "^0.511.0",
    "moving-averages": "^4.0.6",
    "next": "15.3.2",
    "pretty-ms": "^9.2.0",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "tailwind-merge": "^3.3.0"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.11.4",
    "@types/node": "^22.15.21",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "autoprefixer": "^10.4.21",
    "cross-env": "^7.0.3",
    "eslint": "^9.39.4",
    "eslint-config-next": "^15.3.2",
    "postcss": "^8.5.3",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.21.0",
    "typescript": "^5.8.3"
  }
}
