{
  "name": "audiobook-generator",
  "version": "0.1.0",
  "private": true,
  "main": "dist-electron/electron/main.js",
  "scripts": {
    "rebuild:native": "cross-env npm_config_devdir=.cache/node-gyp electron-builder install-app-deps",
    "postinstall": "npm run rebuild:native",
    "build:scripts": "tsc -p tsconfig.scripts.build.json",
    "build:electron": "node -e \"require('fs').rmSync('dist-electron',{recursive:true,force:true})\" && tsc -p tsconfig.electron.json && npm run build:scripts && node dist-scripts/scripts/copy-electron-assets.js",
    "dev:renderer": "cd renderer && next dev -H 127.0.0.1 -p 3000",
    "dev:electron": "electron .",
    "dev:desktop": "npm run build:electron && node dist-scripts/scripts/dev-desktop.js",
    "dev:tauri": "tauri dev",
    "dev": "npm run dev:desktop",
    "build:renderer": "cd renderer && cross-env BUILD_STATIC=1 next build",
    "build:desktop": "npm run build:electron && npm run build:renderer",
    "build:tauri": "tauri build",
    "build:runtime": "tsx scripts/prepare-runtime.ts",
    "smoke:runtime": "tsx scripts/smoke-runtime.ts",
    "build:voice-demos": "tsx scripts/generate-voice-demos.ts",
    "collect:tauri-artifacts": "tsx scripts/collect-tauri-artifacts.ts",
    "build:site": "tsx scripts/build-site.ts",
    "dist:win": "npm run build:desktop && electron-builder --win nsis --x64 --publish never",
    "benchmark:piper": "tsx scripts/benchmark-piper.ts",
    "lint": "cd renderer && next lint",
    "verify:sidecars": "npm run build:scripts && node dist-scripts/scripts/verify-sidecar-manifest.js",
    "test": "tsx --test \"core/**/*.test.ts\"",
    "typecheck": "tsc -p tsconfig.electron.json --noEmit && tsc -p tsconfig.scripts.json && cd renderer && tsc --noEmit"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/modifiers": "^9.0.0",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@radix-ui/react-select": "^2.2.6",
    "@tauri-apps/api": "^2.11.1",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "@tauri-apps/plugin-opener": "^2.5.4",
    "adm-zip": "^0.5.16",
    "better-sqlite3": "^11.8.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "electron-updater": "^6.8.3",
    "epub2": "^3.0.2",
    "fast-xml-parser": "^5.2.5",
    "html-to-text": "^9.0.5",
    "lucide-react": "^0.511.0",
    "moving-averages": "^4.0.6",
    "music-metadata": "^11.9.0",
    "next": "15.3.2",
    "pretty-ms": "^9.2.0",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "sanitize-filename": "^1.6.3",
    "tailwind-merge": "^3.3.0",
    "tree-kill": "^1.2.2"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.11.4",
    "@types/adm-zip": "^0.5.7",
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.15.21",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "@types/sanitize-filename": "^1.6.3",
    "autoprefixer": "^10.4.21",
    "concurrently": "^9.2.0",
    "cross-env": "^7.0.3",
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8",
    "eslint": "^9.39.4",
    "eslint-config-next": "^15.3.2",
    "postcss": "^8.5.3",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.21.0",
    "typescript": "^5.8.3",
    "wait-on": "^8.0.3"
  }
}
